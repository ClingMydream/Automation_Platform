APP_NAME=Automation Platform
APP_ENV=production
APP_SECRET_KEY=change-this-to-a-long-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password
ACCESS_TOKEN_EXPIRE_MINUTES=720

MYSQL_DATABASE=automation_platform
MYSQL_USER=automation
MYSQL_PASSWORD=change-this-mysql-password
MYSQL_ROOT_PASSWORD=change-this-root-password
DATABASE_URL=mysql+pymysql://automation:change-this-mysql-password@mysql:3306/automation_platform?charset=utf8mb4

REDIS_URL=redis://redis:6379/0
PUBLIC_BASE_URL=http://111.229.178.141
ALLOW_PRIVATE_TARGETS=false
EXTERNAL_TRIGGER_TOKEN=change-this-ci-trigger-token
# Comma-separated E.164 numbers that you own or rent for controlled inbound-SMS tests.
TEST_SMS_PHONE_NUMBERS=

FILE_TRANSFER_DIR=/tmp/automation-platform-transfers
FILE_TRANSFER_MAX_MB=1024
FILE_TRANSFER_DEFAULT_HOURS=24

RESULT_ATTACHMENT_DIR=/tmp/automation-platform-attachments
RESULT_ATTACHMENT_MAX_MB=200
UI_RECORD_VIDEO=true
UI_RECORD_VIDEO_MAX_MB=25
UI_DOM_SNAPSHOT_MAX_CHARS=60000
